    {q:"Who gave the slogan 'Do or Die' during the Quit India Movement?",opts:["Nehru","Patel","Gandhi","Subhas Chandra Bose"],ans:2},
    {q:"The Lucknow Pact (1916) was between:",opts:["Congress and Muslim League","Congress and Hindu Mahasabha","Muslim League and the British","Congress and the British"],ans:0},
    {q:"The 'Swadeshi Movement' was launched in response to:",opts:["The Rowlatt Act","The partition of Bengal 1905","The Jallianwala Bagh massacre","The Simon Commission"],ans:1},
    {q:"Who said 'Swaraj is my birthright and I shall have it'?",opts:["Mahatma Gandhi","Jawaharlal Nehru","Bal Gangadhar Tilak","Subhas Chandra Bose"],ans:2},
    {q:"The Khilafat Movement was in support of:",opts:["Ottoman Caliph","Indian Muslims' rights","Pan-Islamic unity in India","Partition of India"],ans:0},
    {q:"Mahatma Gandhi returned to India from South Africa in:",opts:["1912","1913","1915","1917"],ans:2},
    {q:"The Nehru Report (1928) was drafted to propose:",opts:["Dominion status for India","Complete independence","Separate electorates","Federal structure"],ans:0},
    {q:"Who presided over the Karachi Session of Congress (1931)?",opts:["Gandhi","Nehru","Sardar Patel","Subhas Chandra Bose"],ans:2},
    {q:"The 'August Offer' of 1940 was made by:",opts:["Lord Mountbatten","Lord Wavell","Lord Linlithgow","Lord Curzon"],ans:2},
    {q:"Subhas Chandra Bose escaped from India in:",opts:["1939","1940","1941","1942"],ans:2},
    {q:"India became a republic on:",opts:["15 August 1947","26 November 1949","26 January 1950","2 October 1950"],ans:2},
  ]
};

const SET_INFO={
  A:{label:'Set A',desc:'Ancient India',icon:'📜',pill:'set-pill-a',color:'var(--set-a)'},
  B:{label:'Set B',desc:'Medieval India',icon:'🏰',pill:'set-pill-b',color:'var(--set-b)'},
  C:{label:'Set C',desc:'Modern India',icon:'🏛',pill:'set-pill-c',color:'var(--set-c)'},
  D:{label:'Set D',desc:'Freedom Movement',icon:'🇮🇳',pill:'set-pill-d',color:'var(--set-d)'},
};

// STATE
let selectedSet=null,QUESTIONS=[],qState=new Array(25).fill(0),qAnswers=new Array(25).fill(-1);
let currentQ=0,timerInterval=null,timeLeft=30*60,tenMinWarned=false;
let candidateName='',rollNumber='',lastResults=null,currentFilter='all',testStartTime=null;
let fsExitCount=0,fsAutoSubmitTimer=null,fsCountdown=5;
const TOTAL=25;

// ── LOCAL STORAGE ──
const LS_KEY='nta_mock_attempts_v4';
function loadAttempts(){try{return JSON.parse(localStorage.getItem(LS_KEY))||[];}catch{return[];}}
function saveAttempt(a){const arr=loadAttempts();arr.unshift(a);if(arr.length>20)arr.pop();localStorage.setItem(LS_KEY,JSON.stringify(arr));}
function clearAttempts(){if(confirm('Delete all past attempts?')){localStorage.removeItem(LS_KEY);renderHistory();}}

function renderHistory(){
  const body=document.getElementById('history-panel-body');
  const chart=document.getElementById('bar-chart');
  const attempts=loadAttempts();
  const bestScore={A:null,B:null,C:null,D:null};
  attempts.forEach(a=>{if(bestScore[a.set]===null||a.score>bestScore[a.set])bestScore[a.set]=a.score;});
  chart.innerHTML=['A','B','C','D'].map(s=>{
    const si=SET_INFO[s];const best=bestScore[s];const pct=best!==null?Math.max(2,Math.round(best/100*100)):0;const label=best!==null?best+'/100':'\u2014';
    return`<div class="bar-row"><div class="bar-set-label">${si.icon} ${s}</div><div class="bar-track">${best!==null?`<div class="bar-fill bar-fill-${s.toLowerCase()}" style="width:${pct}%"></div>`:''}</div><div class="bar-score-label">${label}</div></div>`;
  }).join('');
  if(!['A','B','C','D'].some(s=>bestScore[s]!==null))chart.innerHTML='<div class="bar-no-attempts">No scores yet \u2014 complete a test!</div>';
  if(!attempts.length){body.innerHTML='<div class="history-empty">No attempts yet.<br/>Complete a test to see history here.</div>';return;}
  body.innerHTML=attempts.map(a=>`<div class="attempt-card"><div class="ac-top"><div class="ac-name">${a.name}</div><div class="ac-date">${a.date}</div></div><div><span class="ac-set-badge badge-${a.set.toLowerCase()}">${SET_INFO[a.set].icon} ${SET_INFO[a.set].label} \u2014 ${SET_INFO[a.set].desc}</span></div><div class="ac-score">${a.score} <span style="font-size:12px;opacity:.55">/ 100</span></div><div class="ac-meta"><span class="ac-badge correct">\u2713 ${a.correct}</span><span class="ac-badge wrong">\u2717 ${a.wrong}</span><span class="ac-badge skip">\u2014 ${a.skip}</span><span class="ac-badge acc">\u26a1 ${a.accuracy}%</span></div></div>`).join('')+`<button class="history-clear-btn" onclick="clearAttempts()">\uD83D\uDDD1 Clear All History</button>`;
}

function selectSet(s){
  selectedSet=s;
  document.querySelectorAll('.set-card').forEach(c=>c.classList.remove('selected'));
  document.getElementById(`sc-${s}`).classList.add('selected');
  const btn=document.getElementById('btn-proceed');btn.disabled=false;btn.textContent=`Start with ${SET_INFO[s].label} (${SET_INFO[s].desc}) \u2192`;
}

// ── PAGE NAVIGATION ──
function showPage(id){
  const root=document.getElementById('nta-fullscreen-root');
  root.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goToStart(){exitFullscreen();clearInterval(timerInterval);clearFsAutoSubmit();document.getElementById('fs-banner').style.display='none';document.getElementById('time-warning').style.display='none';renderHistory();showPage('start-page');}
function goToInstructions(){
  if(!selectedSet){alert('Please select a question paper set first.');return;}
  candidateName=document.getElementById('candidate-name').value.trim()||'Candidate';
  rollNumber=document.getElementById('roll-number').value.trim()||'MOCK000001';
  document.getElementById('inst-name').textContent=candidateName;
  document.getElementById('inst-info').textContent='Roll No: '+rollNumber+' | '+SET_INFO[selectedSet].label;
  document.getElementById('inst-set-label').textContent=SET_INFO[selectedSet].icon+' '+SET_INFO[selectedSet].label+' \u2014 '+SET_INFO[selectedSet].desc;
  document.getElementById('declaration-check').checked=false;
  document.getElementById('proceed-btn').classList.remove('enabled');
  showPage('instruction-page');
}
function toggleProceed(){
  const cb=document.getElementById('declaration-check');
  const vis=document.getElementById('custom-cb-visual');
  if(vis)vis.classList.toggle('checked',cb.checked);
  document.getElementById('proceed-btn').classList.toggle('enabled',cb.checked);
}

// ── FULLSCREEN ──
function enterFullscreen(){const e=document.documentElement;(e.requestFullscreen||e.webkitRequestFullscreen||e.mozRequestFullScreen||function(){}).call(e);}
function exitFullscreen(){try{if(document.fullscreenElement||document.webkitFullscreenElement)(document.exitFullscreen||document.webkitExitFullscreen||function(){}).call(document);}catch(e){}}
function setupFsWatcher(){['fullscreenchange','webkitfullscreenchange','mozfullscreenchange','MSFullscreenChange'].forEach(ev=>document.addEventListener(ev,onFsChange));}
function onFsChange(){
  const isFs=!!(document.fullscreenElement||document.webkitFullscreenElement||document.mozFullScreenElement||document.msFullscreenElement);
  const testOn=document.getElementById('test-page').classList.contains('active');
  if(!testOn){clearFsAutoSubmit();return;}
  if(!isFs){fsExitCount++;fsCountdown=5;document.getElementById('fs-exit-count').textContent='Exits: '+fsExitCount;showFsBanner();startFsCountdown();}
  else{clearFsAutoSubmit();document.getElementById('fs-banner').style.display='none';}
}
function showFsBanner(){document.getElementById('fs-banner').style.display='block';document.getElementById('fs-countdown-text').textContent=fsCountdown;}
function startFsCountdown(){clearFsAutoSubmit();fsAutoSubmitTimer=setInterval(()=>{fsCountdown--;const el=document.getElementById('fs-countdown-text');if(el)el.textContent=fsCountdown;if(fsCountdown<=0){clearFsAutoSubmit();submitTest();}},1000);}
function clearFsAutoSubmit(){if(fsAutoSubmitTimer){clearInterval(fsAutoSubmitTimer);fsAutoSubmitTimer=null;}fsCountdown=5;}

// ── START TEST ──
function startTest(){
  QUESTIONS=QUESTION_SETS[selectedSet];
  qState=new Array(TOTAL).fill(0);qAnswers=new Array(TOTAL).fill(-1);currentQ=0;timeLeft=30*60;tenMinWarned=false;fsExitCount=0;testStartTime=new Date();
  const si=SET_INFO[selectedSet];
  document.getElementById('test-name').textContent=candidateName;document.getElementById('test-roll').textContent=rollNumber;
  document.getElementById('palette-name').textContent=candidateName;document.getElementById('palette-roll').textContent='Roll: '+rollNumber;
  document.getElementById('palette-avatar').textContent=candidateName.charAt(0).toUpperCase()||'?';
  const pill=document.getElementById('test-set-pill');pill.textContent=si.icon+' '+si.label;pill.className='set-pill '+si.pill;
  document.getElementById('section-tab-label').textContent='Section A \u2014 History | '+si.label;
  buildPalette();markVisited(0);renderQuestion();startTimer();showPage('test-page');setTimeout(enterFullscreen,300);
}

// ── TIMER ──
function startTimer(){
  clearInterval(timerInterval);
  timerInterval=setInterval(()=>{
    timeLeft--;
    const m=String(Math.floor(timeLeft/60)).padStart(2,'0'),s=String(timeLeft%60).padStart(2,'0');
    document.getElementById('timer-display').textContent=m+':'+s;
    document.getElementById('timer-box').classList.toggle('urgent',timeLeft<=120);
    if(timeLeft===300&&!tenMinWarned){tenMinWarned=true;document.getElementById('time-warning').style.display='block';setTimeout(()=>document.getElementById('time-warning').style.display='none',6000);}
    if(timeLeft<=0){clearInterval(timerInterval);submitTest();}
  },1000);
}

// ── RENDER QUESTION ──
function renderQuestion(){
  const q=QUESTIONS[currentQ];
  document.getElementById('q-info-label').textContent=`Question No. ${currentQ+1} of ${TOTAL}`;
  const lines=q.q.split('\n');
  let qHtml=`<span class="q-num">${currentQ+1}.</span> ${lines[0]}`;
  if(lines.length>1){qHtml+='<ol class="sub-list">';for(let i=1;i<lines.length;i++)qHtml+=`<li>${lines[i]}</li>`;qHtml+='</ol>';}
  const L=['A','B','C','D'];
  const opts=q.opts.map((o,i)=>`<li class="option-item ${qAnswers[currentQ]===i?'selected':''}" onclick="selectOption(${i})"><input type="radio" name="opt" ${qAnswers[currentQ]===i?'checked':''}/><label><span class="opt-letter">${L[i]})</span>${o}</label></li>`).join('');
  document.getElementById('question-content').innerHTML=`<div class="question-text">${qHtml}</div><ul class="options-list">${opts}</ul>`;
  updatePalette();
}
function selectOption(idx){qAnswers[currentQ]=idx;document.querySelectorAll('.option-item').forEach((el,i)=>{el.classList.toggle('selected',i===idx);el.querySelector('input').checked=(i===idx);});}

// ── NAVIGATION ──
function markVisited(i){if(qState[i]===0)qState[i]=1;}
function saveAndNext(){qState[currentQ]=qAnswers[currentQ]!==-1?((qState[currentQ]===3||qState[currentQ]===4)?4:2):1;updatePalette();goNextQ();}
function markForReview(){qState[currentQ]=qAnswers[currentQ]!==-1?4:3;updatePalette();goNextQ();}
function clearResponse(){qAnswers[currentQ]=-1;qState[currentQ]=1;renderQuestion();updatePalette();}
function prevQuestion(){if(qState[currentQ]===0)qState[currentQ]=1;updatePalette();if(currentQ>0){currentQ--;markVisited(currentQ);renderQuestion();}}
function nextQuestion(){if(qState[currentQ]===0)qState[currentQ]=1;updatePalette();goNextQ();}
function goNextQ(){if(currentQ<TOTAL-1){currentQ++;markVisited(currentQ);renderQuestion();}}
function jumpToQuestion(i){if(qState[currentQ]===0)qState[currentQ]=1;updatePalette();currentQ=i;markVisited(i);renderQuestion();}

// ── PALETTE ──
const SC=['s-nv','s-na','s-ans','s-mk','s-mka'];
function buildPalette(){
  const g=document.getElementById('palette-grid');g.innerHTML='';
  for(let i=0;i<TOTAL;i++){const b=document.createElement('button');b.className=`palette-btn ${SC[qState[i]]}`;b.id=`pb-${i}`;b.textContent=i+1;b.onclick=()=>jumpToQuestion(i);g.appendChild(b);}
}
function updatePalette(){
  let ans=0,na=0,mk=0,nv=0;
  for(let i=0;i<TOTAL;i++){
    const b=document.getElementById(`pb-${i}`);
    if(b){b.className=`palette-btn ${SC[qState[i]]}`;b.classList.toggle('active-q',i===currentQ);}
    if(qState[i]===0)nv++;else if(qState[i]===1)na++;else if(qState[i]===2)ans++;else if(qState[i]===3)mk++;else if(qState[i]===4){ans++;mk++;}
  }
  document.getElementById('stat-ans').textContent=ans;document.getElementById('stat-na').textContent=na;
  document.getElementById('stat-mk').textContent=mk;document.getElementById('stat-nv').textContent=nv;
}

// ── SUBMIT MODAL ──
function openSubmitModal(){
  let ans=0,na=0,mk=0,nv=0;
  qState.forEach(s=>{if(s===0)nv++;else if(s===1)na++;else if(s===2)ans++;else if(s===3)mk++;else if(s===4)ans++;});
  document.getElementById('m-ans').textContent=ans;document.getElementById('m-una').textContent=na;
  document.getElementById('m-mk').textContent=mk;document.getElementById('m-nv').textContent=nv;
  document.getElementById('submit-modal').classList.add('open');
}
function closeSubmitModal(){document.getElementById('submit-modal').classList.remove('open');}
document.getElementById('submit-modal').addEventListener('click',e=>{if(e.target===document.getElementById('submit-modal'))closeSubmitModal();});

// ── SUBMIT TEST ──
function submitTest(){
  clearInterval(timerInterval);clearFsAutoSubmit();closeSubmitModal();exitFullscreen();
  document.getElementById('fs-banner').style.display='none';document.getElementById('time-warning').style.display='none';
  let correct=0,wrong=0,skip=0;
  QUESTIONS.forEach((q,i)=>{const a=qAnswers[i];if(a===-1)skip++;else if(a===q.ans)correct++;else wrong++;});
  const score=correct*4-wrong;const accuracy=correct+wrong>0?Math.round(correct/(correct+wrong)*100):0;
  const endTime=new Date();const timeTakenSec=Math.round((endTime-testStartTime)/1000);const timeTakenStr=Math.floor(timeTakenSec/60)+'m '+(timeTakenSec%60)+'s';
  lastResults={correct,wrong,skip,score,accuracy,set:selectedSet,timeTaken:timeTakenStr};
  const now=new Date();const dateStr=now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})+' '+now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  saveAttempt({name:candidateName,roll:rollNumber,set:selectedSet,score,correct,wrong,skip,accuracy,date:dateStr,answers:[...qAnswers]});
  populatePrintPage(correct,wrong,skip,score,accuracy,dateStr,timeTakenStr);
  const si=SET_INFO[selectedSet];
  document.getElementById('res-set-label').textContent=si.icon+' '+si.label+' \u2014 '+si.desc;
  document.getElementById('res-score').textContent=score;document.getElementById('res-correct').textContent=correct;
  document.getElementById('res-wrong').textContent=wrong;document.getElementById('res-skip').textContent=skip;
  document.getElementById('res-acc').textContent=accuracy+'%';
  showPage('result-page');
}

// ── PRINT / PDF ──
function populatePrintPage(correct,wrong,skip,score,accuracy,dateStr,timeTaken){
  const si=SET_INFO[selectedSet];
  document.getElementById('pr-set-label').textContent=si.icon+' '+si.label+' \u2014 '+si.desc;
  document.getElementById('pr-name').textContent=candidateName;document.getElementById('pr-roll').textContent=rollNumber;
  document.getElementById('pr-date').textContent=dateStr;document.getElementById('pr-time').textContent=timeTaken;
  document.getElementById('pr-score').textContent=score;document.getElementById('pr-correct').textContent=correct;
  document.getElementById('pr-wrong').textContent=wrong;document.getElementById('pr-acc').textContent=accuracy+'%';
  const L=['A','B','C','D'];let tableHtml='';
  QUESTIONS.forEach((q,i)=>{
    const ua=qAnswers[i],ca=q.ans;const youAns=ua===-1?'\u2014':L[ua]+') '+q.opts[ua].substring(0,22)+(q.opts[ua].length>22?'\u2026':'');
    const corrAns=L[ca]+') '+q.opts[ca].substring(0,22)+(q.opts[ca].length>22?'\u2026':'');const cls=ua===-1?'skip':ua===ca?'correct':'wrong';
    const shortQ=q.q.split('\n')[0].substring(0,60)+(q.q.split('\n')[0].length>60?'\u2026':'');
    tableHtml+=`<div class="print-q-row"><div class="pqr-num">Q${i+1}</div><div class="pqr-q">${shortQ}</div><div class="pqr-your ${cls}">${youAns}</div><div class="pqr-correct">${corrAns}</div></div>`;
  });
  document.getElementById('pr-answer-table').innerHTML=tableHtml;
}
function downloadPDF(){window.print();}

// ── REVIEW ──
function showReview(){
  const{correct,wrong,skip,score,set}=lastResults;const si=SET_INFO[set];
  document.getElementById('review-subtitle').textContent=`CUET (UG) 2024 \u2014 History | ${si.icon} ${si.label} \u2014 ${si.desc} | ${candidateName}`;
  document.getElementById('rv-correct').textContent=correct;document.getElementById('rv-wrong').textContent=wrong;
  document.getElementById('rv-skip').textContent=skip;document.getElementById('rv-score').textContent=score;
  document.getElementById('fb-correct').textContent='\u2713 Correct ('+correct+')';
  document.getElementById('fb-wrong').textContent='\u2717 Wrong ('+wrong+')';
  document.getElementById('fb-skip').textContent='\u2014 Skipped ('+skip+')';
  currentFilter='all';document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.filter-btn')[0].classList.add('active');
  renderReviewCards('all');renderNextSetSuggestion();showPage('review-page');
}
function renderNextSetSuggestion(){
  const done=selectedSet;const si=SET_INFO[done];
  document.getElementById('nss-set-done').textContent=si.icon+' '+si.label;
  const attempts=loadAttempts();const attemptedSets=new Set(attempts.map(a=>a.set));const grid=document.getElementById('next-set-grid');
  grid.innerHTML=['A','B','C','D'].map(s=>{
    const info=SET_INFO[s];const isDone=s===done;const wasAttempted=attemptedSets.has(s)&&s!==done;
    const cls=isDone?'next-set-btn done':`next-set-btn nsb-${s.toLowerCase()}`;
    const label=isDone?info.icon+' '+info.label+' (Current)':wasAttempted?info.icon+' '+info.label+' \u21a9 Retry':info.icon+' '+info.label+' \u2014 '+info.desc;
    if(isDone)return`<button class="${cls}" disabled>${label}</button>`;
    return`<button class="${cls}" onclick="switchToSet('${s}')">${label}</button>`;
  }).join('');
}
function switchToSet(s){selectedSet=s;document.querySelectorAll('.set-card').forEach(c=>c.classList.remove('selected'));const sc=document.getElementById(`sc-${s}`);if(sc)sc.classList.add('selected');goToInstructions();}
function setFilter(f,el){currentFilter=f;document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');renderReviewCards(f);}
function renderReviewCards(filter){
  const L=['A','B','C','D'];let html='';
  QUESTIONS.forEach((q,i)=>{
    const ua=qAnswers[i],ca=q.ans;let rc,badge;
    if(ua===-1){rc='r-skipped';badge='<span class="rq-badge skipped">\u2014 Skipped</span>';}
    else if(ua===ca){rc='r-correct';badge='<span class="rq-badge correct">\u2713 Correct (+4)</span>';}
    else{rc='r-wrong';badge='<span class="rq-badge wrong">\u2717 Wrong (\u20131)</span>';}
    if(filter==='correct'&&rc!=='r-correct')return;
    if(filter==='wrong'&&rc!=='r-wrong')return;
    if(filter==='skip'&&rc!=='r-skipped')return;
    const lines=q.q.split('\n');let qh=`<strong>Q${i+1}.</strong> ${lines[0]}`;
    if(lines.length>1){qh+='<ol style="margin:5px 0 5px 18px;line-height:1.85;">';for(let k=1;k<lines.length;k++)qh+=`<li>${lines[k]}</li>`;qh+='</ol>';}
    const opts=q.opts.map((o,j)=>{
      let cls='',ic='plain-icon',it='';
      if(j===ca&&ua===ca){cls='is-user-correct';ic='correct-icon';it='\u2713';}else if(j===ca){cls='is-correct';ic='correct-icon';it='\u2713';}else if(j===ua){cls='is-user-wrong';ic='wrong-icon';it='\u2717';}
      return`<div class="rqc-option ${cls}"><div class="opt-icon ${ic}">${it||L[j]}</div><span><strong>${L[j]})</strong> ${o}</span></div>`;
    }).join('');
    html+=`<div class="review-q-card ${rc}"><div class="rqc-header"><span class="rq-num">Question ${i+1}</span>${badge}</div><div class="rqc-body"><div class="rqc-q-text">${qh}</div><div class="rqc-options">${opts}</div>${ua!==-1?`<div style="font-size:11px;color:var(--muted);margin-top:7px;">Your: <strong>${L[ua]}) ${q.opts[ua]}</strong> &nbsp;|&nbsp; Correct: <strong>${L[ca]}) ${q.opts[ca]}</strong></div>`:''}</div></div>`;
  });
  document.getElementById('review-body').innerHTML=html||'<div style="text-align:center;padding:36px;color:var(--muted);">No questions match this filter.</div>';
}

// ── INIT ──
setupFsWatcher();
renderHistory();
</script>
