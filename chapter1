
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NTA CBT Mock Test Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
body * { box-sizing: border-box; }
#outer-wrapper, .container { padding: 0 !important; margin: 0 !important; }
.test-body {
  display: flex !important; flex-direction: row !important;
  width: 100% !important; height: calc(100vh - 120px) !important;
}
/* ✅ FIX 1: Sidebar width increased slightly to accommodate 5-col palette */
.palette-sidebar {
  width: 260px !important; min-width: 260px !important;
  display: flex !important; flex-direction: column !important;
  position: relative !important; right: 0 !important; top: 0 !important;
  background: #fff !important; z-index: 10;
}
.question-area {
  flex: 1 !important; width: calc(100% - 260px) !important;
}
body, html {
  margin: 0 !important; padding: 0 !important;
  width: 100% !important; overflow-x: hidden !important;
}
#sidebar-wrapper, .sidebar, .widget-area { display: none !important; }
#main-wrapper, .main-wrapper, .content-wrapper {
  width: 100% !important; max-width: 100% !important;
}
.container, .outer-wrapper {
  width: 100% !important; max-width: 100% !important;
  margin: 0 !important; padding: 0 !important;
}
#nta-fullscreen-root {
  position: fixed !important; top: 0; left: 0;
  width: 100vw; height: 100vh; z-index: 999999; background: #fff;
}
#outer-wrapper, #page-wrapper, .container, .post-outer, .post, .section {
  width: 100% !important; max-width: 100% !important;
  margin: 0 !important; padding: 0 !important;
}
header, footer, #header, #footer, .Header, .Footer,
.navbar, .navigation, .blog-pager { display: none !important; }
body { display: block !important; }

:root{
  --p1:#4a2f7a; --p2:#6b46b0; --p3:#8b68cc; --p4:#b89ee0; --p5:#ede8f9; --p6:#f7f4fd;
  --accent:#c084fc;
  --nv:#9e9e9e; --na:#e05c5c; --ans:#3aaa6e; --mk:#d97706; --mka:#0891b2;
  --bg:var(--p6); --card:#fff; --border:var(--p4); --text:#2d1b55; --muted:#6e5d8c;
  --set-a:#6b46b0; --set-b:#0891b2; --set-c:#d97706; --set-d:#3aaa6e;
}
*{box-sizing:border-box;margin:0;padding:0;}
#nta-fullscreen-root {
  font-family:'Noto Sans',sans-serif; color:var(--text); font-size:14px;
}
.page{display:none;height:100vh;overflow:hidden;}
.page.active{display:flex;flex-direction:column;height:100vh;}
#start-page.active{flex-direction:column;overflow-y:auto;}
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--p5);}
::-webkit-scrollbar-thumb{background:var(--p4);border-radius:3px;}

.site-header{background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;box-shadow:0 3px 14px rgba(74,47,122,.35);flex-shrink:0;}
.site-header .top-bar{display:flex;align-items:center;justify-content:space-between;padding:10px 24px;gap:12px;}
.logo-area{display:flex;align-items:center;gap:12px;}
.logo-circle{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.38);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;color:#fff;flex-shrink:0;}
.brand h1{font-size:16px;font-weight:700;}
.brand p{font-size:11px;opacity:.75;margin-top:2px;}
.sub-header{background:rgba(0,0,0,.18);text-align:center;padding:7px 24px;font-size:13px;font-weight:600;letter-spacing:.4px;border-top:1px solid rgba(255,255,255,.1);}

@keyframes slideUp{
  from{opacity:0;transform:translateY(28px) scale(0.98);}
  to{opacity:1;transform:translateY(0) scale(1);}
}
@keyframes fadeIn{
  from{opacity:0;}to{opacity:1;}
}
@keyframes modalIn{
  from{opacity:0;transform:scale(.85) translateY(10px);}
  to{opacity:1;transform:scale(1) translateY(0);}
}
@keyframes shimmer{
  0%{background-position:-200% 0;}
  100%{background-position:200% 0;}
}
@keyframes popIn{
  0%{opacity:0;transform:scale(0.7);}
  70%{transform:scale(1.08);}
  100%{opacity:1;transform:scale(1);}
}

#start-page{
  background:linear-gradient(150deg,#2c1259 0%,#4a2f7a 45%,#6b46b0 100%);
  align-items:center;justify-content:flex-start;
  padding:12px 16px; overflow-y:auto;
}
.start-wrap{
  display:flex;flex-direction:row;gap:14px;
  width:100%;max-width:1040px;
  min-height:calc(100vh - 24px);
  align-items:stretch;
}
.start-left{width:300px;flex-shrink:0;display:flex;flex-direction:column;}
.start-card{background:#fff;border-radius:12px;box-shadow:0 16px 48px rgba(0,0,0,.4);overflow:hidden;flex:1;display:flex;flex-direction:column;animation:slideUp .5s cubic-bezier(0.22,1,0.36,1);}
.start-card-header{background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;padding:14px 22px;text-align:center;flex-shrink:0;}
.nta-logo{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.15);border:2.5px solid rgba(255,255,255,.35);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#fff;margin:0 auto 8px;}
.start-card-header h2{font-size:15px;font-weight:800;}
.start-card-header p{font-size:11px;opacity:.72;margin-top:2px;}
.start-card-body{padding:14px 20px;flex:1;display:flex;flex-direction:column;overflow-y:auto;}
.exam-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px;}
.info-box{background:var(--p5);border:1px solid var(--p4);border-radius:7px;padding:6px 10px;}
.info-box .label{font-size:9px;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:1px;}
.info-box .value{font-size:12px;font-weight:700;color:var(--p1);}
.form-group{margin-bottom:10px;}
.form-group label{display:block;font-size:10px;font-weight:700;color:var(--muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:.5px;}
.form-group input{width:100%;padding:8px 11px;border:1.5px solid var(--p4);border-radius:6px;font-size:13px;font-family:inherit;outline:none;transition:border-color .2s;background:var(--p6);color:var(--text);}
.form-group input:focus{border-color:var(--p2);background:#fff;}
.btn-start{width:100%;padding:11px;background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;border:none;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:.3px;transition:opacity .2s,transform .1s;font-family:inherit;box-shadow:0 4px 14px rgba(74,47,122,.35);margin-top:auto;}
.btn-start:hover{opacity:.95;transform:translateY(-2px);box-shadow:0 8px 24px rgba(74,47,122,.45);}
.btn-start:disabled{opacity:.4;transform:none;cursor:not-allowed;}
.start-right{flex:1;min-width:0;display:flex;flex-direction:column;gap:12px;}
.set-selector-card{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);border-radius:12px;overflow:hidden;flex-shrink:0;animation:slideUp .5s .08s cubic-bezier(0.22,1,0.36,1) both;}
.set-selector-header{background:rgba(255,255,255,.1);color:#fff;padding:10px 16px;border-bottom:1px solid rgba(255,255,255,.1);}
.set-selector-header .ssh-title{font-size:13px;font-weight:700;}
.set-selector-header p{font-size:10.5px;opacity:.65;margin-top:1px;}
.set-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:10px 12px;}
.set-card{border:2px solid;border-radius:9px;padding:9px 10px;cursor:pointer;transition:all .25s cubic-bezier(0.22,1,0.36,1);text-align:center;position:relative;}
.set-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.18);transition:all .25s cubic-bezier(0.22,1,0.36,1);}
.set-card.selected::after{content:'✓';position:absolute;top:5px;right:8px;font-size:12px;font-weight:800;}
.set-card-a{border-color:var(--set-a);background:#f5f0ff;}.set-card-a.selected{background:#ede4ff;box-shadow:0 0 0 2px var(--set-a);}.set-card-a .set-icon,.set-card-a .set-name,.set-card-a.selected::after{color:var(--set-a);}
.set-card-b{border-color:var(--set-b);background:#f0faff;}.set-card-b.selected{background:#dcf4ff;box-shadow:0 0 0 2px var(--set-b);}.set-card-b .set-icon,.set-card-b .set-name,.set-card-b.selected::after{color:var(--set-b);}
.set-card-c{border-color:var(--set-c);background:#fffbf0;}.set-card-c.selected{background:#fff3d4;box-shadow:0 0 0 2px var(--set-c);}.set-card-c .set-icon,.set-card-c .set-name,.set-card-c.selected::after{color:var(--set-c);}
.set-card-d{border-color:var(--set-d);background:#f0fff6;}.set-card-d.selected{background:#d4f5e4;box-shadow:0 0 0 2px var(--set-d);}.set-card-d .set-icon,.set-card-d .set-name,.set-card-d.selected::after{color:var(--set-d);}
.set-icon{font-size:18px;margin-bottom:3px;}
.set-name{font-size:13px;font-weight:800;margin-bottom:1px;}
.set-desc{font-size:10px;color:var(--muted);}
.set-q-count{font-size:9.5px;margin-top:3px;font-weight:600;padding:1px 6px;border-radius:10px;display:inline-block;}
.set-card-a .set-q-count{background:rgba(107,70,176,.12);color:var(--set-a);}
.set-card-b .set-q-count{background:rgba(8,145,178,.12);color:var(--set-b);}
.set-card-c .set-q-count{background:rgba(217,119,6,.12);color:var(--set-c);}
.set-card-d .set-q-count{background:rgba(58,170,110,.12);color:var(--set-d);}
.history-panel{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:12px;overflow:hidden;flex:1;min-height:0;display:flex;flex-direction:column;animation:slideUp .5s .16s cubic-bezier(0.22,1,0.36,1) both;}
.history-panel-header{background:rgba(255,255,255,.1);padding:9px 14px;border-bottom:1px solid rgba(255,255,255,.1);flex-shrink:0;}
.history-panel-header h3{color:#fff;font-size:13px;font-weight:700;}
.history-panel-header p{color:rgba(255,255,255,.5);font-size:10px;margin-top:1px;}
.bar-chart-wrap{padding:10px 14px 8px;border-bottom:1px solid rgba(255,255,255,.1);flex-shrink:0;}
.bar-chart-title{color:rgba(255,255,255,.65);font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin-bottom:7px;}
.bar-chart{display:flex;flex-direction:column;gap:5px;}
.bar-row{display:flex;align-items:center;gap:8px;}
.bar-set-label{color:#fff;font-size:10.5px;font-weight:700;width:44px;flex-shrink:0;}
.bar-track{flex:1;background:rgba(255,255,255,.1);border-radius:20px;height:12px;overflow:hidden;}
.bar-fill{height:100%;border-radius:20px;transition:width .8s cubic-bezier(.4,0,.2,1);min-width:2px;}
.bar-fill-a{background:linear-gradient(90deg,rgba(107,70,176,.6),rgba(107,70,176,.9));}
.bar-fill-b{background:linear-gradient(90deg,rgba(8,145,178,.6),rgba(8,145,178,.9));}
.bar-fill-c{background:linear-gradient(90deg,rgba(217,119,6,.6),rgba(217,119,6,.9));}
.bar-fill-d{background:linear-gradient(90deg,rgba(58,170,110,.6),rgba(58,170,110,.9));}
.bar-score-label{color:rgba(255,255,255,.75);font-size:9.5px;font-weight:700;width:46px;flex-shrink:0;text-align:right;}
.bar-no-attempts{color:rgba(255,255,255,.3);font-size:10.5px;font-style:italic;}
.history-panel-body{padding:8px 10px;overflow-y:auto;flex:1;min-height:0;}
.history-empty{color:rgba(255,255,255,.4);font-size:12px;text-align:center;padding:18px 12px;line-height:1.7;}
.attempt-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:8px 11px;margin-bottom:6px;transition:background .15s;}
.attempt-card:hover{background:rgba(255,255,255,.13);}
.attempt-card .ac-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
.attempt-card .ac-name{color:#fff;font-weight:700;font-size:12px;}
.attempt-card .ac-date{color:rgba(255,255,255,.42);font-size:9.5px;}
.attempt-card .ac-set-badge{font-size:9.5px;font-weight:700;padding:1px 7px;border-radius:10px;margin-bottom:4px;display:inline-block;}
.badge-a{background:rgba(107,70,176,.3);color:#c4a8ff;}
.badge-b{background:rgba(8,145,178,.3);color:#7dd8f0;}
.badge-c{background:rgba(217,119,6,.3);color:#fcd58a;}
.badge-d{background:rgba(58,170,110,.3);color:#8de8b4;}
.attempt-card .ac-score{font-size:18px;font-weight:800;color:#fff;margin-bottom:3px;}
.ac-meta{display:flex;gap:5px;flex-wrap:wrap;}
.ac-badge{font-size:9.5px;font-weight:700;padding:1px 7px;border-radius:20px;}
.ac-badge.correct{background:rgba(58,170,110,.25);color:#6de992;}
.ac-badge.wrong{background:rgba(224,92,92,.25);color:#ff9090;}
.ac-badge.skip{background:rgba(255,255,255,.1);color:rgba(255,255,255,.5);}
.ac-badge.acc{background:rgba(192,132,252,.2);color:#ddb6ff;}
.history-clear-btn{width:100%;padding:6px;background:rgba(224,92,92,.18);border:1px solid rgba(224,92,92,.3);border-radius:6px;color:#ff9090;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:4px;transition:background .15s;}
.history-clear-btn:hover{background:rgba(224,92,92,.38);}

#instruction-page .instruction-body{flex:1;padding:20px;overflow-y:auto;max-width:920px;width:100%;margin:0 auto;}
.instruction-card{background:#fff;border-radius:10px;border:1px solid var(--p4);box-shadow:0 2px 10px rgba(74,47,122,.07);margin-bottom:16px;overflow:hidden;}
.instruction-card-title{background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;padding:11px 18px;font-size:13.5px;font-weight:700;}
.instruction-card-body{padding:16px 20px;}
.instruction-card-body ol,.instruction-card-body ul{padding-left:20px;line-height:1.95;}
.instruction-card-body li{margin-bottom:3px;font-size:13.5px;}
.instruction-card-body li strong{color:var(--p1);}
.legend-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;padding:13px 18px;}
.legend-item{display:flex;align-items:center;gap:9px;font-size:12.5px;}
.legend-bubble{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:#fff;flex-shrink:0;}
.declaration-box{background:var(--p5);border:1.5px solid var(--p4);border-radius:8px;padding:13px 18px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;}
.declaration-box input[type="checkbox"]{
  position:absolute;opacity:0;width:0;height:0;pointer-events:none;
}
.custom-cb-wrap{flex-shrink:0;margin-top:2px;}
.custom-cb{
  width:20px;height:20px;border-radius:4px;
  border:2px solid var(--p4);background:#fff;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s cubic-bezier(0.22,1,0.36,1);
  flex-shrink:0;
}
.custom-cb svg{width:12px;height:10px;opacity:0;transition:opacity .15s;}
.declaration-box input[type="checkbox"]:checked ~ .custom-cb,
.custom-cb.checked{
  background:var(--p2);border-color:var(--p2);
  box-shadow:0 2px 8px rgba(107,70,176,.35);
  transform:scale(1.05);
}
.declaration-box input[type="checkbox"]:checked ~ .custom-cb svg,
.custom-cb.checked svg{opacity:1;}
.declaration-box label{font-size:13px;line-height:1.65;cursor:pointer;}
.instruction-actions{display:flex;justify-content:flex-end;gap:10px;margin-bottom:16px;}
.btn-secondary{padding:10px 22px;background:#fff;color:var(--p2);border:2px solid var(--p2);border-radius:7px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;}
.btn-secondary:hover{background:var(--p5);}
.btn-primary{padding:10px 22px;background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;border:none;border-radius:7px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:inherit;opacity:.4;pointer-events:none;transition:opacity .3s;}
.btn-primary.enabled{opacity:1;pointer-events:auto;}

#fs-banner{display:none;position:fixed;bottom:0;left:0;right:0;background:#c0392b;color:#fff;padding:9px 20px;z-index:2147483646;text-align:center;font-size:13px;font-weight:600;}
.fs-banner-inner{display:flex;align-items:center;justify-content:center;gap:14px;}
#fs-banner .btn-reenter{padding:4px 13px;background:#fff;color:#c0392b;border:none;border-radius:4px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;}
#fs-exit-count{background:rgba(0,0,0,.2);padding:2px 9px;border-radius:12px;font-size:11.5px;}
#time-warning{display:none;position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#fdf4e0;border:2px solid #f59e0b;color:#92400e;padding:11px 22px;border-radius:9px;z-index:2147483645;font-size:13.5px;font-weight:700;box-shadow:0 4px 16px rgba(0,0,0,.12);}
.tw-close{margin-left:12px;cursor:pointer;font-size:15px;opacity:.6;}

#test-page{flex-direction:column;}
.test-header{background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;flex-shrink:0;}
.test-header .top-bar{padding:8px 16px;}
.test-header .brand h1{font-size:15px;}
.set-pill{display:inline-block;padding:2px 10px;border-radius:12px;font-size:11px;font-weight:700;margin-left:8px;}
.set-pill-a{background:rgba(192,132,252,.3);color:#e0c6ff;}
.set-pill-b{background:rgba(103,232,249,.2);color:#a5f0ff;}
.set-pill-c{background:rgba(253,186,116,.2);color:#fde8b4;}
.set-pill-d{background:rgba(110,231,183,.2);color:#bbf7d0;}
.timer-box{background:rgba(255,255,255,.16);border:1.5px solid rgba(255,255,255,.3);border-radius:8px;padding:5px 13px;text-align:center;min-width:118px;}
.timer-label{font-size:9px;text-transform:uppercase;letter-spacing:1px;opacity:.8;}
.timer-value{font-size:20px;font-weight:800;letter-spacing:1px;font-variant-numeric:tabular-nums;}
.timer-box.urgent .timer-value{color:#fca5a5;animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.45;}}
.section-tabs{background:rgba(0,0,0,.18);display:flex;padding:0 16px;border-top:1px solid rgba(255,255,255,.1);}
.section-tab{padding:7px 16px;font-size:12px;font-weight:600;color:rgba(255,255,255,.65);cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;}
.section-tab.active{color:#fff;border-bottom-color:var(--accent);}
.test-body{display:flex;flex:1;overflow:hidden;}
.question-area{flex:1;overflow-y:auto;display:flex;flex-direction:column;}
.question-top-bar{background:var(--p5);border-bottom:1px solid var(--p4);padding:8px 20px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.q-info{font-size:13px;font-weight:700;color:var(--p1);}
.marks-info{font-size:12px;color:var(--muted);}
.marks-info .pos{color:var(--ans);font-weight:700;}
.marks-info .neg{color:var(--na);font-weight:700;}
.question-content{padding:20px 24px;flex:1;}
.question-text{font-size:14.5px;line-height:1.88;color:var(--text);margin-bottom:20px;}
.q-num{font-weight:700;color:var(--p1);}
.sub-list{margin:8px 0 8px 22px;line-height:2.1;}
.options-list{list-style:none;display:flex;flex-direction:column;gap:9px;}
.option-item{display:flex;align-items:flex-start;gap:11px;background:var(--p6);border:1.5px solid var(--p4);border-radius:9px;padding:11px 15px;cursor:pointer;transition:all .2s cubic-bezier(0.22,1,0.36,1);}
.option-item:hover{background:var(--p5);border-color:var(--p3);transform:translateX(3px);}
.option-item.selected{background:#ede4ff;border-color:var(--p2);box-shadow:0 2px 12px rgba(107,70,176,.2);transform:translateX(4px);}
.option-item input{width:15px;height:15px;accent-color:var(--p2);margin-top:2px;flex-shrink:0;cursor:pointer;}
.option-item label{font-size:14px;line-height:1.55;cursor:pointer;flex:1;}
.opt-letter{font-weight:700;color:var(--p2);margin-right:6px;}
.bottom-nav{border-top:1px solid var(--p4);background:#fff;padding:9px 18px;display:flex;gap:7px;flex-wrap:wrap;align-items:center;flex-shrink:0;}
.btn-nav{padding:8px 14px;border-radius:6px;border:1.5px solid;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;}
.btn-nav.save-next{background:var(--p1);color:#fff;border-color:var(--p1);}
.btn-nav.save-next:hover{background:#3a2162;}
.btn-nav.mark-review{background:#d97706;color:#fff;border-color:#d97706;}
.btn-nav.mark-review:hover{background:#b45309;}
.btn-nav.clear{background:#fff;color:var(--na);border-color:var(--na);}
.btn-nav.prev{background:#fff;color:var(--p2);border-color:var(--p2);}
.btn-nav.prev:hover{background:var(--p5);}
